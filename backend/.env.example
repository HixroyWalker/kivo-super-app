# Kivo Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Express Server
PORT=8080
NODE_ENV=development

# Firebase Admin SDK Configuration
# You must download your service account JSON file from the Firebase Console
# and point this path to it, or set the individual GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"

# Lynk API Configuration (For Webhooks and Integration)
LYNK_API_KEY=your_lynk_api_key_here
LYNK_WEBHOOK_SECRET=your_lynk_webhook_secret_here

# Cloudflare Configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id_here
