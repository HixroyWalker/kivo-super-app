{
  "expo": {
    "name": "KIVO",
    "slug": "kivo",
    "version": "1.0.2",
    "runtimeVersion": "1.0.2",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kivowebb.app",
      "buildNumber": "35",
      "infoPlist": {
        "NSCameraUsageDescription": "KIVO needs camera access for KYC liveness checks and scanning QR codes.",
        "NSFaceIDUsageDescription": "KIVO uses FaceID to secure your wallet transactions.",
        "NSPhotoLibraryUsageDescription": "KIVO needs access to your photo library to upload profile pictures and receipts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1E"
      },
      "package": "com.kivowebb.app",
      "versionCode": 29,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "75a49a50-d92c-4ce6-bf92-94037ef68c01"
      },
      "admobAppIdAndroid": "ca-app-pub-3940256099942544~3347511713",
      "admobAppIdIos": "ca-app-pub-3940256099942544~1458002511"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "barcodeScannerEnabled": true,
          "cameraPermission": "KIVO needs camera access for KYC liveness checks and scanning QR codes."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow KIVO to use FaceID for secure payments."
        }
      ],
      "expo-font",
      "expo-router",
      "expo-secure-store"
    ],
    "owner": "walkerha"
  }
}
