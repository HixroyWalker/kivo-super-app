+
+static inline os_log_t getOrCreateInstrumentsLogHandle() {
+  if (!instrumentsLogHandle) {
+    instrumentsLogHandle = os_log_create(
+        "dev.worklets.instruments", OS_LOG_CATEGORY_POINTS_OF_INTEREST);
+  }
