+
+namespace worklets {
+
+#if defined(ANDROID) && defined(WORKLETS_PROFILING)
+
+// avg 6.10 min 2.87 max 7.68 dev 0.42
+// avg 6.09 min 3.29 max 8.62 dev 0.50
