+struct WorkletsSystraceSection {
+ public:
+  template <typename... ConvertsToStringPiece>
+  explicit WorkletsSystraceSection(
+      const char *name,
+      ConvertsToStringPiece &&...args) {
+    os_log_t instrumentsLogHandle = worklets::getOrCreateInstrumentsLogHandle();
